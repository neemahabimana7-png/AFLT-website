# Copy to .env for local development, or set these in Coolify.

DEBUG=False
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=afrilott.com,www.afrilott.com
CSRF_TRUSTED_ORIGINS=https://afrilott.com,https://www.afrilott.com

# Recommended for production (create a PostgreSQL database in Coolify)
# DATABASE_URL=postgres://user:password@postgres:5432/aflt

# Set to true only on the first deploy, then turn off
RUN_SEED_ON_STARTUP=true

# Serve uploaded media files from the app container
SERVE_MEDIA=true

# Optional Gunicorn tuning
GUNICORN_WORKERS=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60
